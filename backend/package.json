{
  "name": "gym-diary-backend",
  "version": "1.0.0",
  "description": "Telegram Mini App - Gym Diary Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/server.ts",
    "build": "tsc && npx prisma generate",
   "start": "npx prisma db push --accept-data-loss && node dist/server.js",
"prisma:migrate": "npx prisma db push --accept-data-loss",
    "prisma:generate": "npx prisma generate",
    "postinstall": "npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "prisma": "^5.7.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
